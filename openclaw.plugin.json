{
  "id": "memory-daymaker",
  "name": "Memory Daymaker",
  "description": "Generate daily OpenClaw memory files from session transcripts with backups, dedupe, and scheduled runs.",
  "version": "0.1.0",
  "activation": {
    "onStartup": true
  },
  "commandAliases": [
    {
      "name": "daymaker",
      "cliCommand": "daymaker"
    }
  ],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "sessionsDir": {
        "type": "string",
        "minLength": 1
      },
      "memoryDir": {
        "type": "string",
        "minLength": 1
      },
      "backupDir": {
        "type": "string"
      },
      "timezone": {
        "type": "string",
        "minLength": 1
      },
      "schedule": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean"
          },
          "time": {
            "type": "string",
            "pattern": "^\\d{1,2}:\\d{2}$"
          },
          "mode": {
            "type": "string",
            "enum": ["auto", "native", "tool"]
          },
          "model": {
            "type": "string",
            "minLength": 1
          },
          "failureAlert": {
            "oneOf": [
              {
                "type": "boolean"
              },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "after": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "channel": {
                    "type": "string",
                    "minLength": 1
                  },
                  "to": {
                    "type": "string",
                    "minLength": 1
                  },
                  "cooldownMs": {
                    "type": "integer",
                    "minimum": 0
                  },
                  "mode": {
                    "type": "string",
                    "enum": ["announce", "webhook"]
                  },
                  "accountId": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            ]
          },
          "delivery": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["announce", "webhook"]
              },
              "channel": {
                "type": "string",
                "minLength": 1
              },
              "to": {
                "type": "string",
                "minLength": 1
              },
              "accountId": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      },
      "model": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
